{
	"name": "ifelseware-avplayback",
	"version": "2.0.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-ifelseware-avplayback.git"
	},
	"engines": {
		"node": "^22.20",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "~1.14.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.7.2",
		"@types/node": "^22.20.0",
		"eslint": "^10.7.0",
		"prettier": "^3.6.2",
		"rimraf": "^6.1.3",
		"typescript": "~5.9.3"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"packageManager": "yarn@4.14.1"
}
